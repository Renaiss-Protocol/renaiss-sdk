{
  "name": "@renaiss-protocol/schema-validation",
  "version": "0.1.0-beta.0",
  "private": true,
  "description": "Zod schemas and shared validation primitives for the Renaiss SDK.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Renaiss-Protocol/renaiss-sdk",
    "directory": "packages/schema-validation"
  },
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  },
  "license": "MIT"
}
